{
  "ci": {
    "collect": {
      "staticDistDir": "./out",
      "url": [
        "http://localhost/index.html",
        "http://localhost/calculator/salary/index.html",
        "http://localhost/calculator/capital-gains-tax/index.html",
        "http://localhost/calculator/loan/index.html",
        "http://localhost/calculator/loan-limit/index.html",
        "http://localhost/calculator/acquisition-tax/index.html",
        "http://localhost/calculator/severance/index.html",
        "http://localhost/category/tax/index.html",
        "http://localhost/category/finance/index.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2", "redirects-http", "is-on-https"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 1500 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2000 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.05 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 150 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
