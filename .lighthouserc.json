{
  "ci": {
    "collect": {
      "staticDistDir": "./out",
      "url": [
        "http://localhost/index.html",
        "http://localhost/updates/index.html",
        "http://localhost/about/index.html",
        "http://localhost/glossary/index.html",
        "http://localhost/guide/index.html",
        "http://localhost/category/work/index.html",
        "http://localhost/category/tax/index.html",
        "http://localhost/category/finance/index.html",
        "http://localhost/category/real-estate/index.html",
        "http://localhost/category/lifestyle/index.html",
        "http://localhost/calculator/salary/index.html",
        "http://localhost/calculator/severance/index.html",
        "http://localhost/calculator/capital-gains-tax/index.html",
        "http://localhost/calculator/acquisition-tax/index.html",
        "http://localhost/calculator/property-tax/index.html",
        "http://localhost/calculator/comprehensive-property-tax/index.html",
        "http://localhost/calculator/loan/index.html",
        "http://localhost/calculator/loan-limit/index.html",
        "http://localhost/calculator/freelancer-tax/index.html",
        "http://localhost/calculator/vat/index.html",
        "http://localhost/calculator/averaging-down/index.html",
        "http://localhost/calculator/split-buy/index.html",
        "http://localhost/calculator/broker-fee/index.html",
        "http://localhost/calculator/rent-conversion/index.html",
        "http://localhost/calculator/exchange/index.html",
        "http://localhost/calculator/bmi/index.html",
        "http://localhost/calculator/d-day/index.html",
        "http://localhost/guide/tax-calendar-2026/index.html",
        "http://localhost/guide/may-comprehensive-income-tax/index.html",
        "http://localhost/guide/june-property-tax/index.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2", "redirects-http", "is-on-https"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 1500 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2000 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.05 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 150 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
