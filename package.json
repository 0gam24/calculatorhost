{
  "name": "calculatorhost",
  "version": "0.1.0",
  "private": true,
  "description": "한국 생활 금융·세금·부동산 계산기 종합 사이트",
  "scripts": {
    "dev": "next dev",
    "dev:functions": "wrangler pages dev out --local --port 3000",
    "sync-data": "node scripts/sync-public-data.mjs",
    "gen-og": "node scripts/generate-og-images.mjs",
    "seo:validate": "node scripts/validate-seo.mjs",
    "prebuild": "node scripts/generate-og-images.mjs && node scripts/sync-public-data.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky || true"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.0.3",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
