{
  "name": "calculatorhost",
  "version": "0.1.0",
  "private": true,
  "description": "한국 생활 금융·세금·부동산 계산기 종합 사이트",
  "scripts": {
    "dev": "next dev",
    "dev:functions": "wrangler pages dev out --local --port 3000",
    "sync-data": "node scripts/sync-public-data.mjs",
    "sync:health": "node scripts/check-sync-health.mjs",
    "gen-og": "node scripts/generate-og-images.mjs",
    "seo:validate": "node scripts/validate-seo.mjs",
    "audit:adsense": "node scripts/audit-adsense.mjs",
    "generate:mirror": "node scripts/generate-network-mirror.mjs",
    "generate:today": "node scripts/generate-today.mjs",
    "generate:today:dry": "node scripts/generate-today.mjs --dry-run",
    "ralph:auto-guide": "node scripts/ralph-auto-guide.mjs",
    "ralph:auto-guide:dry": "node scripts/ralph-auto-guide.mjs --dry-run",
    "ralph:check-guide": "node scripts/check-guide-quality.mjs",
    "ralph:meta": "node scripts/ralph-meta-audit.mjs",
    "ralph:meta:fix": "node scripts/ralph-meta-audit.mjs --auto-fix",
    "ralph:link-health": "node scripts/ralph-link-health.mjs",
    "ralph:seasonal": "node scripts/ralph-seasonal-guide.mjs",
    "ralph:tax-check": "node scripts/ralph-tax-cross-check.mjs",
    "ralph:visual": "node scripts/ralph-visual-diff.mjs",
    "ralph:bundle": "node scripts/ralph-bundle-size.mjs",
    "state": "node scripts/check-state.mjs",
    "launch:checklist": "node scripts/launch-checklist.mjs",
    "prebuild": "node scripts/generate-og-images.mjs && node scripts/sync-public-data.mjs && node scripts/generate-network-mirror.mjs && node scripts/check-state.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky || true",
    "ralph:faq": "node scripts/ralph-faq-suggest.mjs",
    "ralph:lh": "node scripts/ralph-lh-regression.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260503.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.0.3",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "browserslist": {
    "production": [
      "Chrome >= 100",
      "Firefox >= 100",
      "Safari >= 15.4",
      "Edge >= 100",
      "Samsung >= 19",
      "not dead",
      "not ie 11",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
