# calculatorhost 환경변수 예시
# 실제 키는 .env.local 또는 Cloudflare Pages 대시보드에 설정
# 절대 커밋 금지

# ===== AdSense =====
# 프로덕션 AdSense 퍼블리셔 ID (public 값이지만 dev 에선 가짜 사용 권장)
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-0000000000000000

# 광고 단위 ID — AdSense 대시보드 → 광고 → 광고 단위 별 → "데이터-광고-슬롯" 의 숫자값
# 단일 fallback (포맷별 ID 미설정 시 모두 이 값 사용)
NEXT_PUBLIC_ADSENSE_SLOT_DEFAULT=0000000000

# 포맷별 광고 단위 ID — 인벤토리 매칭 최적화 (포맷별로 별도 광고 단위 생성 필요)
# AdSense 대시보드에서 4개 광고 단위를 만들고 각 슬롯 ID 입력
NEXT_PUBLIC_ADSENSE_SLOT_LEADERBOARD=0000000000   # 728x90 / 970x250 (헤더 아래)
NEXT_PUBLIC_ADSENSE_SLOT_RECTANGLE=0000000000     # 300x250 (계산기-본문 사이)
NEXT_PUBLIC_ADSENSE_SLOT_SKYSCRAPER=0000000000    # 300x600 (우측 사이드바)
NEXT_PUBLIC_ADSENSE_SLOT_INFEED=0000000000        # 인피드 반응형 (본문 단락 사이)
NEXT_PUBLIC_ADSENSE_SLOT_ANCHOR=0000000000        # 320x50 / 320x100 (모바일 앵커)

# ===== Phase H: Cloudflare Pages Functions (실시간 API 프록시) =====
# 키는 Cloudflare Pages 프로젝트 환경변수에서 설정 (코드에서는 context.env.X로 접근)
# 브라우저에 절대 노출 금지. 서버(Functions)에서만 사용

# 공공데이터포털 서비스키 (RTMS 아파트 매매 실거래, JUSO 도로명주소)
# 신청: https://www.data.go.kr
#   1. 원하는 API 검색 (예: "아파트 매매 신고 조회")
#   2. 상세페이지 → "활용신청" 클릭
#   3. 이용목적·운영여부 선택 → 신청
#   4. 승인 대기 (보통 1-3일)
#   5. 마이페이지 → 내 활용신청 → 인증키 복사
# Cloudflare Pages 환경변수: PUBLIC_DATA_KEY
PUBLIC_DATA_KEY=YOUR_PUBLIC_DATA_KEY_HERE

# 행안부 도로명주소 API (JUSO) — 주소 자동완성 (선택)
# 신청: https://business.juso.go.kr/addrlink → 회원가입 → 서비스 신청
# Cloudflare Pages 환경변수: JUSO_API_KEY (별도로 설정하지 않으면 PUBLIC_DATA_KEY 사용)
# JUSO_API_KEY=YOUR_JUSO_KEY_HERE

# ===== 공공 API 인증키 (선택사항 — 미설정 시 정적 기본값 사용) =====

# 한국은행 ECOS API — 기준금리·CPI
# 신청: https://ecos.bok.or.kr → 회원가입 → 인증키 신청
ECOS_API_KEY=YOUR_ECOS_API_KEY_HERE

# 한국수출입은행 환율 API — 매매기준율
# 신청: https://www.koreaexim.go.kr/site/program/financial/exchangeJSON
EXIM_FX_API_KEY=YOUR_EXIM_FX_API_KEY_HERE

# 금융감독원 금융상품통합비교공시 API — 정기예금·적금 평균금리
# 신청: https://finlife.fss.or.kr/finlifeapi/ → 회원가입 → 인증키 신청
FSS_FINLIFE_API_KEY=YOUR_FSS_FINLIFE_API_KEY_HERE

# 통계청 KOSIS API — 가구 월평균 소득
# 신청: https://kosis.kr → 회원가입 → 인증키 신청
KOSIS_API_KEY=YOUR_KOSIS_API_KEY_HERE

# ===== 분석 / 검색엔진 인증 =====
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Naver 웹로그분석 (Naver Analytics) — 한국 검색 25% 점유, GA4 외 별도 추적 필수.
# 발급 ID 형식: a + 10자리 이상 숫자 (예: a1234567890123)
# 등록: https://wa.naver.com → 사이트 등록 → 발급 ID 복사
NEXT_PUBLIC_NAVER_ANALYTICS_ID=aXXXXXXXXXXXX

# Google Search Console — HTML 태그 인증 시 google-site-verification 의 content 값
# 등록: https://search.google.com/search-console → 속성 추가 → URL 접두어 → HTML 태그
NEXT_PUBLIC_SEARCH_CONSOLE_VERIFICATION=

# Naver Search Advisor — naver-site-verification 의 content 값 (한국 검색 25%)
# 등록: https://searchadvisor.naver.com → 사이트 추가 → HTML 태그 인증
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=

# ===== 소셜 / 카카오톡 공유 =====
# Kakao Developers JavaScript Key (브라우저 공개됨 OK — 도메인 화이트리스트로 보호)
# 등록: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키 복사
# 플랫폼 등록: 사이트 도메인에 https://calculatorhost.com 추가 필수
NEXT_PUBLIC_KAKAO_JS_KEY=

# Organization JSON-LD sameAs — 운영자/사이트 공식 SNS·외부 프로필 URL (콤마 구분)
# Knowledge Graph 신뢰도 ↑. 실제 운영 중인 프로필만 입력 (404·placeholder 금지).
# 예: "https://blog.naver.com/smartdatashop,https://brunch.co.kr/@smartdatashop,https://www.youtube.com/@calculatorhost"
NEXT_PUBLIC_SAMEAS_URLS=

# ===== 어필리에이트 파트너 URL (선택, 가입 후 입력) =====
# 모든 키는 운영자가 각 파트너 사이트에 가입 → 추적 코드 포함된 URL 발급 → 여기 입력.
# 미입력 시 사이트에 어필리에이트 UI 자동 비표시 (운영자 가입 전 안전 비활성).
# 표시광고법·공정위 가이드라인 준수: 모든 링크에 "광고" 라벨 자동 부여.
# 정책: https://calculatorhost.com/affiliate-disclosure/
#
# 본 목록은 모두 공개 가입 가능한 프로그램만 등재 (검증 완료).
# 비공개·B2B 전용 프로그램(삼쩜삼·뱅크샐러드 등)은 운영자가 직접 contact 후 별도 등록.

# 쿠팡 파트너스 — 도서·전자책·생활용품 (CPS, 도서 3%)
# 가입: https://partners.coupang.com (즉시 승인)
# 활용 예: 가이드 끝 "관련 도서" 섹션 → 절세 책·재테크 책 추천
NEXT_PUBLIC_AFFILIATE_COUPANG_URL=

# 알라딘 TTB — 국내 도서 어필리에이트 (TTB 코드 기반)
# 가입: https://blog.aladin.co.kr/ttb/ → 신청 후 승인
# 활용 예: 도서 인용·서평형 가이드
NEXT_PUBLIC_AFFILIATE_ALADIN_URL=

# 카카오뱅크 친구추천 — 적금·예금·체크카드 가입 보너스
# 가입: 카카오뱅크 앱 → 더보기 → 친구초대 → 추천 링크 복사
# 활용 예: /calculator/savings/, /calculator/deposit/
NEXT_PUBLIC_AFFILIATE_KAKAOBANK_URL=

# 토스 친구초대 — 체크카드·적금 등 가입 보너스
# 가입: 토스 앱 → 전체 → 친구 초대 → 추천 링크 복사
# 활용 예: /calculator/exchange/, /calculator/savings/
NEXT_PUBLIC_AFFILIATE_TOSS_URL=

# 링크프라이스 — 한국 어필리에이트 네트워크 (다수 광고주)
# 가입: https://www.linkprice.com → 미디어 회원 신청 → 캠페인별 추적 링크 발급
# 활용 예: 광고주별로 적절한 페이지에 배치 (가입 후 사용 가능 캠페인 확인)
NEXT_PUBLIC_AFFILIATE_LINKPRICE_URL=

# ===== 자동 가이드 발행 (Phase 2, scripts/ralph-auto-guide.mjs) =====
# Anthropic Claude API 키 — 시즌별 가이드 자동 초안 생성용.
# 절대 NEXT_PUBLIC_ 접두 사용 금지 (브라우저 노출 방지).
# 신청: https://console.anthropic.com → API Keys → Create Key
# GitHub Actions: Settings → Secrets and variables → Actions → New repository secret
# 로컬 dev: .my 또는 .env.local 에 설정 (gitignore 처리됨, 절대 커밋 금지)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# 자동 가이드 cron 활성 토글 (GitHub Actions vars)
# Settings → Secrets and variables → Actions → Variables → AUTO_GUIDE_ENABLED=true 로 설정해야
# 매주 cron 자동 실행. 수동(workflow_dispatch)은 항상 가능.
# AUTO_GUIDE_ENABLED=false (기본값)

# ===== Bing IndexNow — 새 글 색인 자동 핑 =====
# 용도: .github/workflows/indexnow-ping.yml 가 머지 후 Bing/Yandex 등에 색인 알림.
# 발급: https://www.bing.com/indexnow → "Generate API key" → 32자 hex 문자열
# 특이사항: 공개 식별자 (public/<KEY>.txt 파일로 게시되어 Bing 검증) — PAT 같은 secret 아님.
# GitHub Actions 등록: Settings → Secrets → Actions → INDEXNOW_KEY
# public/ 에도 <KEY>.txt 생성 필수 (Bing 도메인 소유 검증).
INDEXNOW_KEY=YOUR_INDEXNOW_KEY_HERE

# ===== GitHub PAT (Personal Access Token) — auto-guide-cron PR 생성용 =====
# 용도: GitHub Actions 가 PR 을 생성할 때 사용 (GITHUB_TOKEN 은 createPullRequest 거부됨).
# 발급: https://github.com/settings/tokens → Generate new token (classic)
#   Note: calculatorhost-auto-guide
#   Expiration: 90일 권장 (또는 No expiration — 운영자 보안 정책에 따라)
#   Scopes: repo (전체 체크 — Full control of private repositories)
# GitHub Actions 등록: Settings → Secrets and variables → Actions → New repository secret
#   Name: GH_PAT
#   Secret: 발급한 PAT 문자열
# 로컬 dev: .env.local 에 보관 (gitignore 처리됨, 절대 커밋 금지)
#   ※ 로컬 스크립트 실행 시 사용 안 함 (gh CLI 가 별도 auth 처리). 발급 후 안전 보관용.
GH_PAT=YOUR_GITHUB_PAT_HERE

# ===== 배포 =====
SITE_URL=https://calculatorhost.com

# ===== GitHub (MCP용) =====
# GITHUB_TOKEN 은 보통 gh CLI로 자동 관리
