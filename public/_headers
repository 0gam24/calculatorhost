# Cloudflare Pages 캐시 정책 명시
# 정적 자산은 hash 기반 cache-busting → 1년 immutable
# HTML/sitemap 등은 짧은 TTL

# Next.js 빌드 산출물 (해시된 파일명) — 영구 캐시
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted 폰트 (변경 시 파일명 변경) — 1년
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Open Graph 이미지 — 30일
/og-default.png
  Cache-Control: public, max-age=2592000

/og-default.svg
  Cache-Control: public, max-age=2592000

# 파비콘 — 7일
/favicon.ico
  Cache-Control: public, max-age=604800

# robots.txt — 4시간 (정책 변경 빠른 반영)
/robots.txt
  Cache-Control: public, max-age=14400, must-revalidate

# sitemap.xml — 1시간 (lastmod 변경 빠른 반영)
/sitemap.xml
  Cache-Control: public, max-age=3600, must-revalidate

# ads.txt — 24시간
/ads.txt
  Cache-Control: public, max-age=86400

# llms.txt — 4시간 (LLM 디스커버리 정책 빠른 반영)
/llms.txt
  Cache-Control: public, max-age=14400, must-revalidate
  Content-Type: text/plain; charset=utf-8

# site.webmanifest — 1주일 (PWA 메타 변경 빈도 낮음)
/site.webmanifest
  Cache-Control: public, max-age=604800
  Content-Type: application/manifest+json; charset=utf-8

# HTML 페이지 — 짧은 TTL + revalidate + 보안/프라이버시 헤더
# 정적 export 라 콘텐츠 자체는 자주 변경 X, 그래도 새 배포 빠른 반영 위해 1시간
#
# 보안 헤더 (외부 평가 기준 — securityheaders.com / Mozilla Observatory):
# - HSTS: 1년 + subdomain 포함 + preload (브라우저가 HTTPS 강제)
# - CSP: report-only 모드로 시작 (1주일 위반 모니터링 후 enforce 전환 예정)
#   허용 origin: 'self' + Google AdSense + GA4 + Google Fonts + 정적 이미지
/*
  Cache-Control: public, max-age=3600, must-revalidate
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://pagead2.googlesyndication.com https://www.googletagmanager.com https://www.google-analytics.com https://adservice.google.com https://*.googlesyndication.com https://*.adtrafficquality.google https://static.cloudflareinsights.com https://t1.kakaocdn.net https://developers.kakao.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://*.googlesyndication.com https://pagead2.googlesyndication.com https://*.adtrafficquality.google https://cloudflareinsights.com https://*.kakao.com https://kapi.kakao.com; frame-src https://googleads.g.doubleclick.net https://*.googlesyndication.com https://*.adtrafficquality.google https://www.google.com https://sharer.kakao.com; object-src 'none'; base-uri 'self'; form-action 'self'
