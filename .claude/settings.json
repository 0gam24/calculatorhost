{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(pnpm:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git pull)",
      "Bash(git remote:*)",
      "Bash(git restore:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(gh issue:*)",
      "Bash(gh repo view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(jq:*)",
      "Bash(curl:*)",
      "Bash(wrangler:*)",
      "Bash(vercel:*)",
      "Read(**)",
      "Grep(**)",
      "Glob(**)",
      "Write(src/**)",
      "Write(content/**)",
      "Write(docs/**)",
      "Write(tests/**)",
      "Write(scripts/**)",
      "Write(public/**)",
      "Write(.claude/**)",
      "Write(.github/**)",
      "Write(CLAUDE.md)",
      "Write(README.md)",
      "Write(.gitignore)",
      "Write(package.json)",
      "Write(tsconfig.json)",
      "Write(next.config.ts)",
      "Write(tailwind.config.ts)",
      "Write(.env.example)",
      "Edit(**)",
      "WebFetch(domain:developers.google.com)",
      "WebFetch(domain:web.dev)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:data.go.kr)",
      "WebFetch(domain:www.data.go.kr)",
      "WebFetch(domain:ecos.bok.or.kr)",
      "WebFetch(domain:nts.go.kr)",
      "WebFetch(domain:hometax.go.kr)",
      "WebFetch(domain:moef.go.kr)",
      "WebFetch(domain:law.go.kr)",
      "WebFetch(domain:rt.molit.go.kr)",
      "WebFetch(domain:kosis.kr)",
      "WebFetch(domain:finlife.fss.or.kr)",
      "WebFetch(domain:support.google.com)",
      "WebFetch(domain:schema.org)",
      "WebFetch(domain:validator.schema.org)",
      "WebFetch(domain:search.google.com)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf .)",
      "Bash(rm -rf /)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(sudo:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",

      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",

      "Bash(git reset --hard origin/main)",
      "Bash(git clean -fdx)",
      "Bash(git branch -D main)",
      "Bash(git branch -D master)",
      "Bash(chmod 777:*)",

      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo delete:*)",

      "Write(.env.production)",
      "Write(.env.production.local)",
      "Write(**/secrets.json)",
      "Write(**/credentials.json)",
      "Write(secrets/**)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*service-account*.json)",
      "Edit(.env.production)",
      "Edit(.env.production.local)",
      "Edit(**/secrets.json)",
      "Edit(**/credentials.json)",
      "Edit(secrets/**)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(.env.development.local)",
      "Read(.env.production.local)",
      "Read(.my)",
      "Read(.my.*)",
      "Read(*.my)",
      "Read(**/secrets.json)",
      "Read(**/credentials.json)",
      "Read(secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*service-account*.json)",
      "Read(**/.npmrc)",
      "Read(**/.netrc)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",

      "Bash(cat .env*)",
      "Bash(cat .my*)",
      "Bash(cat *.my)",
      "Bash(cat secrets/**)",
      "Bash(cat **/*.pem)",
      "Bash(cat **/*.key)",
      "Bash(cat **/credentials*)",
      "Bash(cat **/secrets*)",
      "Bash(grep .my:*)",
      "Bash(grep .env:*)",
      "Bash(head .my:*)",
      "Bash(tail .my:*)",
      "Bash(less .my:*)",
      "Bash(more .my:*)",
      "Bash(env)",
      "Bash(printenv)",
      "Bash(echo $*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(npm publish:*)",
      "Bash(wrangler deploy:*)",
      "Bash(vercel deploy:*)",

      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.development.local)",
      "Write(.my)",
      "Write(.my.*)",
      "Write(*.my)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.development.local)",
      "Edit(.my)",
      "Edit(.my.*)",
      "Edit(*.my)"
    ]
  },
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-haiku-4-5"
  },
  "includeCoAuthoredBy": true,
  "statusLine": {
    "type": "command",
    "command": "cat .claude/progress.md 2>/dev/null | head -1 || echo 'calculatorhost | 기획 단계'"
  }
}
